{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Vestige",
    "version": "1.0.0",
    "identifier": "vestige",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Vestige",
                "width": 1280,
                "height": 800,
                "minWidth": 960,
                "minHeight": 640
            }
        ],
        "security": {
            "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://*:8080 https://*:8080; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
        }
    },
    "bundle": {
        "active": true,
        "targets": ["nsis", "msi"],
        "resources": [
            "resources/docker-compose.yml",
            "resources/.env.template",
            "resources/books_config.json"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
